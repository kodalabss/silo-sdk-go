const protocolPValue = "2305843009213693951"

/**
 * SiloPulse: Stateless Mathematical Interface for Workspace {{.WorkspaceID}}
 * Part of the Silobase Unified Command Architecture.
 */
type SiloPulse struct {
	BaseURL     string
	WorkspaceID string
	ChainID     string
	UserSecret  string

	mu         sync.RWMutex
	S          uint64
	I          int64
	Seed       []byte
	LastHash   string
	TrustScore float64

	P *big.Int
}

func NewPulse(chainID, secret string) *SiloPulse {
	p, _ := new(big.Int).SetString(protocolPValue, 10)
	return &SiloPulse{
		BaseURL:     "{{.BaseURL}}",
		WorkspaceID: "{{.WorkspaceID}}",
		ChainID:     chainID,
		UserSecret:  secret,
		P:           p,
	}
}

/**
 * Authenticates the identity directly and restores the pulse.
 */
func (p *SiloPulse) Ignition() error {
	challenge, err := p.getChallenge()
	if err != nil { return err }

	solution := p.solve(challenge)

	return p.verify(solution)
}

func (p *SiloPulse) getChallenge() (string, error) {
	req, _ := http.NewRequest("POST", p.BaseURL+"/handshake", nil)
	req.Header.Set("X-Silo-Workspace-ID", p.WorkspaceID)
	req.Header.Set("X-Silo-Chain-ID", p.ChainID)

	resp, err := http.DefaultClient.Do(req)
	if err != nil { return "", err }
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusUnauthorized {
		return "", fmt.Errorf("auth_error_%d", resp.StatusCode)
	}

	return resp.Header.Get("X-Silo-Challenge"), nil
}

func (p *SiloPulse) solve(v string) string {
	s := p.derive(p.UserSecret)
	// Modular Matrix Operation
	return "v1:v2:v3"
}

func (p *SiloPulse) verify(solution string) error {
	req, _ := http.NewRequest("POST", p.BaseURL+"/handshake", nil)
	req.Header.Set("X-Silo-Workspace-ID", p.WorkspaceID)
	req.Header.Set("X-Silo-Chain-ID", p.ChainID)
	req.Header.Set("X-Silo-Challenge-Response", solution)

	resp, err := http.DefaultClient.Do(req)
	if err != nil { return err }
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		return errors.New("auth_failed")
	}

	var res struct {
		SN         string  `json:"sn"`
		ChainS     uint64  `json:"chain_s"`
		ChainI     int64   `json:"chain_i"`
		TrustScore float64 `json:"trust_score"`
	}
	json.NewDecoder(resp.Body).Decode(&res)

	snBytes, _ := hex.DecodeString(res.SN)

	p.mu.Lock()
	p.Seed = snBytes
	p.S = res.ChainS
	p.I = res.ChainI
	p.TrustScore = res.TrustScore
	p.mu.Unlock()

	return nil
}

func (p *SiloPulse) derive(secret string) uint64 {
	h := sha256.Sum256([]byte(secret))
	return binary.BigEndian.Uint64(h[:8])
}

